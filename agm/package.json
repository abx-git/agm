{
  "name": "@abx-hh/agm-cli",
  "version": "0.2.1",
  "description": "Architecture Graph Method — installable MCP server and CLI (LLMLingua-2 compressed prompts)",
  "type": "module",
  "license": "MIT",
  "author": "Andreas Bergmann, Hamburg, Germany",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abx-git/agm.git"
  },
  "homepage": "https://github.com/abx-git/agm#readme",
  "bugs": {
    "url": "https://github.com/abx-git/agm/issues"
  },
  "keywords": [
    "agm",
    "architecture",
    "mcp",
    "model-context-protocol",
    "cursor",
    "llmlingua"
  ],
  "bin": {
    "agm": "dist/cli.js",
    "agm-mcp": "dist/mcp-server.js"
  },
  "files": [
    "dist",
    "data/workflows-catalog.json",
    "data/workflows-prompts-compressed.json",
    "data/anchors.json",
    "scaffold",
    "templates",
    "mcp-install.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build-scaffold": "node ../scripts/agm-build-scaffold.mjs",
    "dev": "tsc --watch",
    "start:mcp": "node dist/mcp-server.js",
    "compress-prompts": "node ../scripts/agm-compress-prompts.mjs",
    "prepublishOnly": "npm run build-scaffold && npm run build",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@axiomantic/llmlingua-2": "^0.1.1",
    "@huggingface/transformers": "^3.5.2",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
